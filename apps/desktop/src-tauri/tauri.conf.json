{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Zoro",
  "identifier": "com.zoro.app",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "bash ../../scripts/build-mcp-sidecar.sh && pnpm dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash ../../scripts/build-mcp-sidecar.sh --release && pnpm build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zoro",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.zoro/**", "$HOME/workspace/**", "/tmp/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/zoro-mcp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk0OEZENUQzODI1QjQ5MTQKUldRVVNWdUMwOVdQbERZeTNvSkVhZkFHOWp0Qi93YzllbnFTRjh4ZFZGRzV1elBSRXRUNTlZMU0K",
      "endpoints": [
        "https://github.com/ruihanglix/zoro/releases/latest/download/latest.json"
      ]
    }
  }
}
